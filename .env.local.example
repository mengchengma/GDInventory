# Supabase — get these from your Supabase project: Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Auth gate — shared credential for the team
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# A long random string. Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-64-char-hex-string
